# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase 프로젝트 설정에서 확인 (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>   # 서버 전용, 절대 클라이언트에 노출 금지

# ── App ───────────────────────────────────────────────────────────────────────
# 배포 시 실제 도메인으로 변경. 미설정 시 request origin에서 자동 추론.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── DeepL (채팅 번역) ─────────────────────────────────────────────────────────
# https://www.deepl.com/account/summary 에서 발급
# 미설정 시 번역 없이 원문만 표시 (graceful degradation)
DEEPL_API_KEY=<deepl-auth-key>

# ── Cron ──────────────────────────────────────────────────────────────────────
# /api/cron/* 엔드포인트 보호용 시크릿. 임의 문자열로 설정.
# 호출 시 헤더: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=<random-secret-string>

# ── 계정 휴면 정책 ────────────────────────────────────────────────────────────
# 마지막 활동 후 N일 경과 시 휴면 처리. 미설정 시 기본값 사용.
DORMANT_INACTIVE_DAYS=180
